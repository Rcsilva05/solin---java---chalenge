          }
        }
      ]
    },
    {
      "name": "3. Pets",
      "item": [
        {
          "name": "Cadastrar pet",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Rex\",\n  \"raca\": \"Golden Retriever\",\n  \"dataNascimento\": \"2020-03-15\",\n  \"pesoKg\": 28.5,\n  \"sexo\": \"MACHO\",\n  \"tutorId\": 1,\n  \"especieId\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/pets", "host": ["{{baseUrl}}"], "path": ["api", "pets"] }
          }
        },
        {
          "name": "Listar pets (filtros + paginacao)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/pets?nome=rex&especieId=1&page=0&size=10&sort=nome,asc", "host": ["{{baseUrl}}"], "path": ["api", "pets"], "query": [{"key":"nome","value":"rex"},{"key":"especieId","value":"1"},{"key":"page","value":"0"},{"key":"size","value":"10"},{"key":"sort","value":"nome,asc"}] }
          }
        },
        {
          "name": "Buscar pet por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/pets/1", "host": ["{{baseUrl}}"], "path": ["api", "pets", "1"] }
          }
        },
        {
          "name": "Atualizar pet",
          "request": {
            "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Rex Junior\",\n  \"raca\": \"Golden Retriever\",\n  \"dataNascimento\": \"2020-03-15\",\n  \"pesoKg\": 30.0,\n  \"sexo\": \"MACHO\",\n  \"tutorId\": 1,\n  \"especieId\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/pets/1", "host": ["{{baseUrl}}"], "path": ["api", "pets", "1"] }
          }
        },
        {
          "name": "Excluir pet",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/pets/1", "host": ["{{baseUrl}}"], "path": ["api", "pets", "1"] }
          }
        }
      ]
    },
    {
      "name": "4. Eventos",
      "item": [
        {
          "name": "Registrar evento URINOU (recente, nao gera alerta)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"URINOU\",\n  \"dataHora\": \"2026-05-17T10:00:00\",\n  \"origem\": \"MANUAL\",\n  \"observacao\": \"Check-in da manha\",\n  \"petId\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/eventos", "host": ["{{baseUrl}}"], "path": ["api", "eventos"] }
          },
          "description": "Use uma data/hora proxima da atual para nao disparar alerta. Ajuste a dataHora conforme o dia que voce esta testando."
        },
        {
          "name": "Registrar evento URINOU antigo (gera ALERTA AMARELO ou VERMELHO)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"URINOU\",\n  \"dataHora\": \"2026-05-15T08:00:00\",\n  \"origem\": \"SENSOR_IOT\",\n  \"observacao\": \"Sensor PIR detectou uso da caixa de areia\",\n  \"petId\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/eventos", "host": ["{{baseUrl}}"], "path": ["api", "eventos"] }
          },
          "description": "Registrando um evento URINOU com data antiga, a proxima chamada de criacao de evento (ou esta mesma se for o unico registro) fara o sistema considerar que o pet esta ha muitas horas sem urinar e disparar alerta."
        },
        {
          "name": "Registrar evento COMEU",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"COMEU\",\n  \"dataHora\": \"2026-05-17T07:30:00\",\n  \"origem\": \"MANUAL\",\n  \"observacao\": \"Racao premium - 200g\",\n  \"petId\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/eventos", "host": ["{{baseUrl}}"], "path": ["api", "eventos"] }
          }
        },
        {
          "name": "Listar eventos do pet (com filtros)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/eventos/pet/1?tipo=URINOU&page=0&size=20&sort=dataHora,desc", "host": ["{{baseUrl}}"], "path": ["api", "eventos", "pet", "1"], "query": [{"key":"tipo","value":"URINOU"},{"key":"page","value":"0"},{"key":"size","value":"20"},{"key":"sort","value":"dataHora,desc"}] }
          }
        },
        {
          "name": "Listar eventos por intervalo de data",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/eventos/pet/1?inicio=2026-05-01T00:00:00&fim=2026-05-31T23:59:59&page=0&size=50", "host": ["{{baseUrl}}"], "path": ["api", "eventos", "pet", "1"], "query": [{"key":"inicio","value":"2026-05-01T00:00:00"},{"key":"fim","value":"2026-05-31T23:59:59"},{"key":"page","value":"0"},{"key":"size","value":"50"}] }
          }
        },
        {
          "name": "Buscar evento por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/eventos/1", "host": ["{{baseUrl}}"], "path": ["api", "eventos", "1"] }
          }
        },
        {
          "name": "Excluir evento",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/eventos/1", "host": ["{{baseUrl}}"], "path": ["api", "eventos", "1"] }
          }
        }
      ]
    },
    {
      "name": "5. Alertas",
      "item": [
        {
          "name": "Listar alertas do pet",
          "request": {
            "method": "GET",
            "header": [],
