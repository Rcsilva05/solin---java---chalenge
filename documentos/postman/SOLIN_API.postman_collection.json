    },
    {
      "name": "6. Testes de erro",
      "item": [
        {
          "name": "404 - Recurso inexistente",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/pets/9999", "host": ["{{baseUrl}}"], "path": ["api", "pets", "9999"] }
          }
        },
        {
          "name": "422 - Regra de negocio (email duplicado)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Outro Tutor\",\n  \"email\": \"maria.silva@email.com\",\n  \"telefone\": \"(11) 91111-1111\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tutores", "host": ["{{baseUrl}}"], "path": ["api", "tutores"] }
          },
          "description": "Cadastre 'maria.silva@email.com' primeiro (request 'Cadastrar tutor' da pasta 2), depois execute este para ver o 422."
        }
      ]
    }
