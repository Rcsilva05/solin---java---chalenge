          }
        },
        {
          "name": "Buscar alerta por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/alertas/1", "host": ["{{baseUrl}}"], "path": ["api", "alertas", "1"] }
          }
        },
        {
          "name": "Marcar alerta como resolvido",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/alertas/1/resolver", "host": ["{{baseUrl}}"], "path": ["api", "alertas", "1", "resolver"] }
          }
        }
