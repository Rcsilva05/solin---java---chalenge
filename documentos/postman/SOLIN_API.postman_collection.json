{
  "info": {
    "name": "SOLIN API - Sprint 1",
    "description": "Colecao de testes da API SOLIN. Suba a aplicacao no perfil dev (./mvnw spring-boot:run) e execute as requisicoes na ordem das pastas. O perfil dev ja vem com 3 especies pre-cadastradas (Cao, Gato, Coelho).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/solin", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Especies",
      "item": [
        {
          "name": "Listar especies",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/especies?page=0&size=10&sort=nome,asc", "host": ["{{baseUrl}}"], "path": ["api", "especies"], "query": [{"key":"page","value":"0"},{"key":"size","value":"10"},{"key":"sort","value":"nome,asc"}] }
          }
        },
        {
          "name": "Buscar especie por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/especies/1", "host": ["{{baseUrl}}"], "path": ["api", "especies", "1"] }
          }
        },
        {
          "name": "Cadastrar especie",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Hamster\",\n  \"horasMaximasSemUrinar\": 6\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/especies", "host": ["{{baseUrl}}"], "path": ["api", "especies"] }
          }
        },
        {
          "name": "Atualizar especie",
          "request": {
            "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cao adulto\",\n  \"horasMaximasSemUrinar\": 10\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/especies/1", "host": ["{{baseUrl}}"], "path": ["api", "especies", "1"] }
          }
        },
        {
          "name": "Excluir especie",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/especies/4", "host": ["{{baseUrl}}"], "path": ["api", "especies", "4"] }
          }
        }
      ]
    },
    {
      "name": "2. Tutores",
      "item": [
        {
          "name": "Cadastrar tutor",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Silva\",\n  \"email\": \"maria.silva@email.com\",\n  \"telefone\": \"(11) 91234-5678\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tutores", "host": ["{{baseUrl}}"], "path": ["api", "tutores"] }
          }
        },
        {
          "name": "Cadastrar tutor (validacao falhando)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"M\",\n  \"email\": \"email-invalido\",\n  \"telefone\": \"abc\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tutores", "host": ["{{baseUrl}}"], "path": ["api", "tutores"] }
          },
          "description": "Demonstra Bean Validation: retorna 400 com lista detalhada de erros."
        },
        {
          "name": "Listar tutores (paginado, busca por nome)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tutores?nome=mar&page=0&size=10&sort=nome,asc", "host": ["{{baseUrl}}"], "path": ["api", "tutores"], "query": [{"key":"nome","value":"mar"},{"key":"page","value":"0"},{"key":"size","value":"10"},{"key":"sort","value":"nome,asc"}] }
          }
        },
        {
          "name": "Buscar tutor por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tutores/1", "host": ["{{baseUrl}}"], "path": ["api", "tutores", "1"] }
          }
        },
        {
          "name": "Atualizar tutor",
          "request": {
            "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria S. Oliveira\",\n  \"email\": \"maria.oliveira@email.com\",\n  \"telefone\": \"(11) 98888-7777\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tutores/1", "host": ["{{baseUrl}}"], "path": ["api", "tutores", "1"] }
          }
        },
        {
          "name": "Excluir tutor",
          "request": {
            "method": "DELETE",
            "header": [],
